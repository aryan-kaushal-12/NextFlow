# =============================================================================
# NextFlow — copy to .env.local and replace every INSERT_* value.
# Never commit .env.local (it is gitignored).
# =============================================================================

# --- PostgreSQL (e.g. Neon: https://neon.tech) ---
DATABASE_URL="INSERT_POSTGRES_CONNECTION_STRING"

# --- Clerk (https://dashboard.clerk.com → API Keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="INSERT_CLERK_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="INSERT_CLERK_SECRET_KEY"

# Optional Clerk URLs (defaults work for this app if routes match)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/workflow"
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/workflow"

# --- Transloadit (https://transloadit.com → Credentials) ---
NEXT_PUBLIC_TRANSLOADIT_KEY="INSERT_TRANSLOADIT_KEY"
TRANSLOADIT_SECRET="INSERT_TRANSLOADIT_SECRET"

# --- Google Gemini (https://aistudio.google.com → API key) ---
# Required by Trigger.dev tasks (llm-node). Also set this in Trigger.dev
# project → Environment variables for deployed workers.
GEMINI_API_KEY="INSERT_GEMINI_API_KEY"

# --- OpenAI (https://platform.openai.com/api-keys) ---
# Used by llm-node when selecting an openai:* model.
OPENAI_API_KEY="INSERT_OPENAI_API_KEY"

# --- Hugging Face Inference API (https://huggingface.co/settings/tokens) ---
# Used by llm-node when selecting hf:blip-image-captioning-base.
HF_API_TOKEN="INSERT_HF_API_TOKEN"

# --- Ollama (free local models) ---
# Install: https://ollama.com/download
# Then pull a model, e.g. `ollama pull mistral`
# If omitted, defaults to http://127.0.0.1:11434
# OLLAMA_BASE_URL="http://127.0.0.1:11434"

# --- Trigger.dev (https://trigger.dev → your project → API keys) ---
# Used when Next.js calls workflowOrchestrator.trigger() from /api/workflow/run
TRIGGER_SECRET_KEY="INSERT_TRIGGER_SECRET_KEY"
