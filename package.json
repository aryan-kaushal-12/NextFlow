    "@trigger.dev/sdk": "4.4.3",
    "axios": "^1.7.2",
    "immer": "^10.1.1",
    "lucide-react": "^0.395.0",
    "next": "14.2.4",
    "probe-image-size": "^7.2.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "reactflow": "^11.11.4",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@trigger.dev/build": "4.4.3",
    "@types/node": "^20",
